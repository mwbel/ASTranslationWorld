const __sutraInstallAutoEnglishTarget = () => {
  if (window.__sutraLocalAutoEnglishTargetInstalled) return;
  window.__sutraLocalAutoEnglishTargetInstalled = true;

  let timer = 0;
  let lastSwitchKey = "";

  const countMatches = (text, pattern) => (String(text || "").match(pattern) || []).length;

  const currentSourceSample = () => Array.from(document.querySelectorAll(
    ".text-source-viewer__text, .source-token"
  ))
    .slice(0, 120)
    .map((node) => node.textContent || "")
    .join("")
    .slice(0, 1200);

  const shouldPreferEnglish = () => {
    const sample = currentSourceSample();
    if (!sample) return false;
    const zhCount = countMatches(sample, /[\u3400-\u9fff]/g);
    const boCount = countMatches(sample, /[\u0f00-\u0fff]/g);
    return zhCount >= Math.max(16, boCount * 2);
  };

  const maybeSwitch = () => {
    timer = 0;
    const activeTab = document.querySelector(".lang-tab.active");
    if (!activeTab || !activeTab.textContent.includes("中文")) return;
    const englishTab = Array.from(document.querySelectorAll(".lang-tab"))
      .find((tab) => tab.textContent.includes("English"));
    if (!englishTab || !shouldPreferEnglish()) return;

